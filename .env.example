# === LLM Configuration ===
# Configure at least one provider (or use the Setup page after launching)

# Ollama (local, free) — install from https://ollama.ai
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1

# OpenAI
# OPENAI_API_KEY=sk-xxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx

# === Database (defaults work with docker compose) ===
DATABASE_URL=postgresql+asyncpg://socratiq:socratiq@db:5432/socratiq
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# === Whisper ASR ===
# Mode: "api" (recommended) or "local" (requires PyTorch + openai-whisper installed)
WHISPER_MODE=api

# Groq (free tier, fast) — get key at console.groq.com
WHISPER_API_KEY=gsk_xxx
WHISPER_API_BASE_URL=https://api.groq.com/openai/v1
WHISPER_API_MODEL=whisper-large-v3

# Alternatives:
# SiliconFlow: WHISPER_API_BASE_URL=https://api.siliconflow.cn/v1  model=FunAudioLLM/SenseVoiceSmall
# OpenAI:      WHISPER_API_BASE_URL=https://api.openai.com/v1      model=whisper-1

# === Security ===
JWT_SECRET_KEY=change-me-in-production
LLM_ENCRYPTION_KEY=change-me-too

# === Bilibili (optional) ===
# BILIBILI_SESSDATA=
# BILIBILI_BILI_JCT=
# BILIBILI_BUVID3=
